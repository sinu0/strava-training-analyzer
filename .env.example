# === Database ===
DB_PASSWORD=change-me-in-prod

# === Strava OAuth2 ===
STRAVA_CLIENT_ID=your-client-id
STRAVA_CLIENT_SECRET=your-client-secret
STRAVA_WEBHOOK_TOKEN=random-webhook-verify-token

# === Security ===
JWT_SECRET=change-me-random-32-char-secret
ENCRYPTION_KEY=change-me-random-32-byte-hex-key

# === Routing ===
# BRouter is the preferred cycling route engine used by /api/routes/preview
ROUTING_BROUTER_ENABLED=true
ROUTING_BROUTER_URL=https://brouter.de/brouter
ROUTING_OSRM_ENABLED=true
ROUTING_OSRM_URL=https://router.project-osrm.org
