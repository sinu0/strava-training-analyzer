# === Database ===
DB_PASSWORD=change-me-in-prod

# === Strava OAuth2 ===
STRAVA_CLIENT_ID=your-client-id
STRAVA_CLIENT_SECRET=your-client-secret
STRAVA_WEBHOOK_TOKEN=random-webhook-verify-token

# === Security ===
JWT_SECRET=change-me-random-32-char-secret
ENCRYPTION_KEY=change-me-random-32-byte-hex-key

# Aplikacja jest domyślnie local-only. Aby uruchomić opcjonalny kontener Ollama,
# ustaw jednocześnie AI_ENABLED=true i COMPOSE_PROFILES=ai.
AI_ENABLED=false
COMPOSE_PROFILES=
