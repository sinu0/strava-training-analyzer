{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["summary", "insight", "action", "metrics", "confidence", "reasoning"],
  "properties": {
    "summary": {
      "type": "string",
      "maxLength": 160,
      "description": "One direct, actionable statement. Do not use markdown."
    },
    "insight": {
      "type": "string",
      "maxLength": 600,
      "description": "2-4 sentences explaining WHY based on data."
    },
    "action": {
      "type": "string",
      "maxLength": 300,
      "description": "Single concrete next step with specific targets (duration, power, HR, cadence)."
    },
    "metrics": {
      "type": "object",
      "minProperties": 3,
      "maxProperties": 10,
      "additionalProperties": {"type": "string"},
      "description": "Key data points supporting the recommendation."
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "confidence_breakdown": {
      "type": "object",
      "properties": {
        "data_quality": {"type": "number", "minimum": 0.0, "maximum": 1.0},
        "trend_clarity": {"type": "number", "minimum": 0.0, "maximum": 1.0},
        "model_certainty": {"type": "number", "minimum": 0.0, "maximum": 1.0}
      }
    },
    "reasoning": {
      "type": "string",
      "description": "Full technical justification for internal coach review. Step by step."
    },
    "warnings": {
      "type": "array",
      "items": {"type": "string"}
    },
    "alternatives": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "scenario": {"type": "string"},
          "action": {"type": "string"}
        }
      }
    },
    "references": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Training methodology or scientific framework citations."
    },
    "structured_workout": {
      "type": "object",
      "properties": {
        "type": {"type": "string", "enum": ["endurance", "intervals", "recovery", "race_simulation"]},
        "total_duration_min": {"type": "integer"},
        "intervals": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "duration_sec": {"type": "integer"},
              "power_target": {"type": "string"},
              "cadence": {"type": "string"},
              "description": {"type": "string"}
            }
          }
        }
      }
    }
  }
}

Expected response (JSON only, no text outside):
{
  "summary": "<1-2 sentences, <=160 chars, actionable>",
  "insight": "<2-4 sentences explaining the WHY based on data>",
  "action": "<single concrete next step with specific targets>",
  "metrics": {"<key>": "<value>"},
  "confidence": <0.0-1.0>,
  "confidence_breakdown": {"data_quality": <0.0-1.0>, "trend_clarity": <0.0-1.0>, "model_certainty": <0.0-1.0>},
  "reasoning": "<full technical justification, step by step>",
  "warnings": ["<caution if any, else empty array>"],
  "alternatives": [{"scenario": "<what-if>", "action": "<alternative action>"}],
  "references": ["<training framework or scientific paper citation>"],
  "structured_workout": null
}
